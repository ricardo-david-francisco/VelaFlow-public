# VelaFlow Enterprise — Premium Tier Container
# Includes local LLM inference (Ollama) for true privacy
# Designed for nested LXC or dedicated K8s pod with GPU access
#
# KEDA scales these pods based on premium LLM request queue depth.
# In LXC mode, this runs as a nested container for isolation.

FROM python:3.11-slim AS base

LABEL maintainer="VelaFlow Contributors"
LABEL description="VelaFlow Premium — Local LLM inference for privacy-first tenants"

RUN groupadd -r velaflow && useradd -r -g velaflow -d /app -s /sbin/nologin velaflow

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Install Ollama for local LLM inference
RUN curl -fsSL https://ollama.ai/install.sh | sh || true

COPY pyproject.toml requirements.txt ./
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir "fastapi>=0.115.0" "uvicorn[standard]>=0.32.0" "pydantic>=2.10.0"

COPY src/ ./src/
COPY prompts/ ./prompts/
COPY deploy/docker/entrypoint-premium.sh ./entrypoint.sh
RUN chmod +x ./entrypoint.sh

RUN mkdir -p /app/data/medallion && chown -R velaflow:velaflow /app

EXPOSE 8000
EXPOSE 11434

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/health && curl -f http://localhost:11434/api/tags || exit 1

CMD ["./entrypoint.sh"]
