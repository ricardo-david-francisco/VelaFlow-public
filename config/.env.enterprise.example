# =============================================================================
# VelaFlow Enterprise — Environment Configuration
# =============================================================================
# Copy to config/.env.enterprise and fill in your values.
# This extends the base .env with multi-tenant platform settings.

# ── JWT Authentication ─────────────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# ── Field Encryption ───────────────────────────────────────────────────
# Master key for tenant data encryption (AES-256).
# Generate with: python -c "from brain.security.encryption import FieldEncryptor; print(FieldEncryptor.generate_master_key())"
VELAFLOW_MASTER_KEY=

# ── Medallion Storage ──────────────────────────────────────────────────
# Directory for Bronze/Silver/Gold data layers
VELAFLOW_DATA_DIR=/opt/velaflow/data/medallion

# ── API Configuration ──────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://velaflow.example.com
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ── Redis Queue ────────────────────────────────────────────────────────
# Required for async pipeline processing in multi-node deployments
REDIS_URL=redis://localhost:6379/0

# ── Premium Tier (Local LLM) ──────────────────────────────────────────
# Nested LXC / K8s pod running Ollama for privacy-first tenants
PREMIUM_LLM_ENABLED=false
PREMIUM_LLM_URL=http://10.0.3.100:11434
PREMIUM_LLM_MODEL=qwen2:1.5b

# ── DuckDB Engine (on-prem analytical processing) ────────────────────
DUCKDB_MEMORY_LIMIT=512MB
VELAFLOW_DUCKDB_PATH=/opt/velaflow/data/velaflow.duckdb
VELAFLOW_CATALOG_DB=/opt/velaflow/data/catalog.db

# ── Zero-Trust Component Secret ─────────────────────────────────
# Shared secret for inter-service HMAC request signing (API ↔ Worker ↔ n8n)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
VELAFLOW_COMPONENT_SECRET=

# ── Base VelaFlow Settings ─────────────────────────────────────────────
# These are inherited from the single-tenant configuration.
# See config/.env.example for full documentation.
TODOIST_API_TOKEN=
NOTION_API_TOKEN=
GOOGLE_AI_API_KEY=
TZ=Europe/Lisbon
