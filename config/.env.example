# ============================================================
# VelaFlow — Configuration
# Copy to config/.env and fill in your values
# ============================================================

# --- Todoist (REQUIRED) ---
TODOIST_API_TOKEN=your_todoist_api_token_here

# --- Email Delivery (REQUIRED) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
DIGEST_FROM_EMAIL=your.email@gmail.com
DIGEST_TO_EMAIL=your.email@gmail.com

# --- Notion Integration (REQUIRED for dashboard sync) ---
NOTION_API_TOKEN=your_notion_integration_token_here
NOTION_ROOT_PAGE_ID=                        # 2nd-Brain root page ID
# The following are auto-filled by: brain notion-setup
NOTION_COMMAND_CENTER_ID=
NOTION_DAILY_PLANNER_DB_ID=
NOTION_WEEKLY_PLANNER_DB_ID=
NOTION_WEEKEND_PLANNER_DB_ID=
NOTION_BOARD_DB_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Zero-Trust Proxy Model (RECOMMENDED for all LXC deployments)
#
# Real API keys live ONLY on your VPS running LiteLLM.
# This container holds only a budget-capped proxy token.
# See docs/security.md for the full setup guide.
#
# Personal use:  generate a token with a comfortable monthly budget (e.g. $20)
# Demo handover: generate a token with a hard cap of $1-2, 48 h expiry, IP lock
# ─────────────────────────────────────────────────────────────────────────────
LITELLM_PROXY_URL=https://your-litellm-proxy.example.com
LITELLM_PROXY_TOKEN=sk-proxy-xxxxxxxxxxxxxxxxxxxxxxxx
LITELLM_PROXY_MODEL=gemini/gemini-2.5-flash

# DEMO_MODE=true  → proxy is mandatory; direct key fallback is disabled
# Set this in any container you hand to a third party.
DEMO_MODE=false

# BRAIN_READ_ONLY=true → blocks Notion→Todoist write-back
# Set this in any container you hand to a third party.
BRAIN_READ_ONLY=false

# ─────────────────────────────────────────────────────────────────────────────
# Direct AI keys (OPTIONAL — local dev only)
# WARNING: do NOT set these in an LXC you share with others.
# If LITELLM_PROXY_URL is set, these are used only as a last-resort fallback.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-pro
GOOGLE_AI_FALLBACK_MODEL=gemini-2.5-flash
GOOGLE_AI_LITE_MODEL=gemini-2.5-flash-lite

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- WhatsApp via CallMeBot (OPTIONAL) ---
CALLMEBOT_PHONE=+XXXXXXXXXXX
CALLMEBOT_API_KEY=your_callmebot_api_key
# Optional: secondary notification recipient
CALLMEBOT_SECONDARY_PHONE=+XXXXXXXXXXX
CALLMEBOT_SECONDARY_API_KEY=your_secondary_callmebot_api_key

# --- Gmail IMAP Alerts (OPTIONAL) ---
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_USERNAME=your.email@gmail.com
GMAIL_IMAP_PASSWORD=your_gmail_app_password_here
GMAIL_IMPORTANT_QUERY=X-GM-RAW "label:important is:unread newer_than:1d"

# --- Google Calendar (OPTIONAL — requires OAuth2 setup) ---
GOOGLE_OAUTH_CLIENT_SECRETS_FILE=credentials.json
GOOGLE_OAUTH_TOKEN_FILE=.google-token.json

# --- NotebookLM Integration (OPTIONAL) ---
# Requires: pip install 'notebooklm-py[browser]' && playwright install chromium
# One-time auth: notebooklm login
# NOTEBOOKLM_NOTEBOOK_ID is printed on the first brain notebooklm-sync run.
NOTEBOOKLM_NOTEBOOK_ID=
NOTEBOOKLM_NOTEBOOK_NAME=VelaFlow

# --- Todoist Labels ---
TODOIST_FOCUS_LABEL=focus
TODOIST_WEEKEND_LABEL=weekend
TODOIST_KANBAN_PROJECT_ID=

# --- Todoist Planner Sections (auto-filled by: brain notion-setup) ---
TODOIST_DAILY_PLANNER_SECTION_ID=
TODOIST_WEEKLY_PLANNER_SECTION_ID=
TODOIST_WEEKEND_PLANNER_SECTION_ID=

# --- Schedule Defaults ---
WORKDAY_START_HOUR=9
WORKDAY_END_HOUR=18
WEEKEND_DAY_START_HOUR=9
WEEKEND_DAY_END_HOUR=18
DEFAULT_TASK_DURATION_MINUTES=30
WEEKEND_CAPACITY_HOURS=3

# --- Digest Limits ---
DAILY_TOP_TASK_LIMIT=5
OVERDUE_SECTION_LIMIT=7
WEEKEND_TASK_LIMIT=8

# --- Timezone ---
TZ=Europe/Lisbon
