# ═══════════════════════════════════════════════════════════════════════
# VelaFlow — One-Click Deploy Configuration
#
# Copy this file and fill in your values:
#   cp config/.env.deploy.example config/.env.deploy
#   nano config/.env.deploy
#
# Then deploy:
#   bash scripts/deploy-full-stack.sh --config config/.env.deploy
# ═══════════════════════════════════════════════════════════════════════

# ── LXC Container (Proxmox) ──────────────────────────────────────────
CTID=200                    # Container ID on Proxmox
LXC_HOSTNAME=velaflow       # Container hostname
LXC_RAM=1024                # RAM in MB (1024 for personal, 2048+ for enterprise)
LXC_CORES=2                 # CPU cores
LXC_DISK=10                 # Disk size in GB
LXC_STORAGE=local-lvm       # Proxmox storage pool
LXC_BRIDGE=vmbr0            # Network bridge

# ── VPS / LiteLLM Proxy ─────────────────────────────────────────────
# Your personal VPS where the real API keys live (Zero-Trust Proxy).
# The LXC never sees these keys — only a budget-capped proxy token.
VPS_HOST=                   # e.g., proxy.yourdomain.com or 203.0.113.10
VPS_USER=root               # SSH user on VPS (must have key auth)
DOMAIN=                     # Domain for TLS cert (e.g., proxy.yourdomain.com)
CERTBOT_EMAIL=admin@yourdomain.com

# ── API Keys (stored ONLY on VPS, never in LXC) ─────────────────────
GEMINI_API_KEY=             # REQUIRED — Google AI Studio key (https://aistudio.google.com)
OPENAI_API_KEY=             # Optional — OpenAI key for GPT models
GROQ_API_KEY=               # Optional — Groq key for Llama models
LITELLM_MASTER_KEY=         # Auto-generated if empty

# ── Application Secrets ──────────────────────────────────────────────
TODOIST_API_TOKEN=          # REQUIRED — Todoist API token (https://app.todoist.com/app/settings/integrations/developer)

# Notion (optional — enhances dashboard sync)
NOTION_API_TOKEN=           # Notion internal integration token
NOTION_ROOT_PAGE_ID=        # Root page ID for dashboard

# Email (optional — daily digest delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=              # Gmail address
SMTP_PASSWORD=              # Gmail App Password (not regular password)
DIGEST_FROM_EMAIL=          # Same as SMTP_USERNAME
DIGEST_TO_EMAIL=            # Recipient email

# WhatsApp (optional — overdue alerts)
WHATSAPP_PHONE_NUMBER=      # With country code, e.g., +351912345678
CALLMEBOT_API_KEY=          # From CallMeBot registration

# ── NotebookLM ───────────────────────────────────────────────────────
SKIP_NOTEBOOKLM=false       # Set true to skip NotebookLM entirely
PUSH_NOTEBOOKLM_AUTH=false  # Set true if you have cookies on Proxmox host
NLM_COOKIE_PATH=            # Path to storage_state.json on Proxmox host
# If PUSH_NOTEBOOKLM_AUTH=false and SKIP_NOTEBOOKLM=false:
#   Deploy script will start a VNC session for manual Google login.

# ── Premium LLM (optional) ──────────────────────────────────────────
SETUP_PREMIUM_LLM=false     # Set true to create nested LXC with Ollama
LLM_MODEL=qwen2:1.5b        # Ollama model (934 MB, fits 4 GB RAM)

# ── Skip Flags ───────────────────────────────────────────────────────
SKIP_LXC=false              # Set true to reuse existing container
SKIP_PROXY=false            # Set true if proxy is already deployed
