# ═══════════════════════════════════════════════════════════════════════
# VelaFlow — Production Environment Configuration
# Copy to config/.env and fill in required values.
# Deploy with: sudo bash deploy/cloud/setup-vm.sh
# ═══════════════════════════════════════════════════════════════════════

# --- Domain (REQUIRED) ---
VELAFLOW_DOMAIN=your-domain.com

# --- Owner Email (REQUIRED — auto-promoted to admin on registration) ---
VELAFLOW_OWNER_EMAIL=your-admin-email@example.com

# --- Google OAuth (REQUIRED for n8n auth proxy + Google login) ---
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
OAUTH2_PROXY_EMAIL_DOMAINS=gmail.com

# --- Security Secrets (auto-generated by setup-vm.sh if blank) ---
JWT_SECRET=
VELAFLOW_MASTER_KEY=
N8N_ENCRYPTION_KEY=
REDIS_PASSWORD=
OAUTH2_PROXY_COOKIE_SECRET=

# --- LiteLLM Proxy (RECOMMENDED — single token for all LLM access) ---
LITELLM_PROXY_URL=https://your-litellm-proxy.example.com
LITELLM_PROXY_TOKEN=sk-proxy-xxxxxxxxxxxxxxxxxxxxxxxx
LITELLM_PROXY_MODEL=gemini/gemini-2.5-flash

# --- Direct AI Keys (OPTIONAL — fallback only) ---
GOOGLE_AI_API_KEY=
GROQ_API_KEY=

# --- Email (OPTIONAL — for digest delivery) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
DIGEST_FROM_EMAIL=
DIGEST_TO_EMAIL=

# --- Todoist (OPTIONAL — can be set per-tenant via API) ---
TODOIST_API_TOKEN=

# --- Notion (OPTIONAL — can be set per-tenant via API) ---
NOTION_API_TOKEN=

# --- Timezone ---
TZ=Europe/Lisbon
ENVIRONMENT=production
