# Demo LXC environment — Zero-Trust Proxy Model
# Copy to config/.env inside the demo LXC container.
# This file contains ZERO real API keys.
# See docs/security.md for the full security architecture.

# ── Zero-Trust Proxy (REQUIRED in demo mode) ──────────────────────────────────
# All AI calls are routed through the LiteLLM proxy on your VPS.
# Real Gemini/OpenAI keys never leave your personal server.
LITELLM_PROXY_URL=https://proxy.yourdomain.com
LITELLM_PROXY_TOKEN=sk-demo-REPLACE_WITH_ISSUED_TOKEN
LITELLM_PROXY_MODEL=gemini/gemini-2.5-flash

# demo_mode=true disables the direct Gemini/Groq fallback chain.
# If the proxy is unreachable, the system returns a graceful error
# rather than leaking the absence of real keys.
DEMO_MODE=true

# brain_read_only=true prevents demo users from writing tasks back to Todoist
# via Notion. They can browse and see all data, but cannot create/modify Todoist tasks.
BRAIN_READ_ONLY=true

# ── Todoist (safe — scoped integration token) ─────────────────────────────────
# Issue a separate Todoist app token scoped to a demo project.
# Do NOT use your personal full-access token here.
TODOIST_API_TOKEN=REPLACE_WITH_DEMO_TODOIST_TOKEN
TODOIST_KANBAN_PROJECT_ID=REPLACE_WITH_DEMO_PROJECT_ID

# Planner section IDs (created by: brain notion-setup)
TODOIST_DAILY_PLANNER_SECTION_ID=
TODOIST_WEEKLY_PLANNER_SECTION_ID=
TODOIST_WEEKEND_PLANNER_SECTION_ID=

# ── Notion (safe — limited to demo workspace) ─────────────────────────────────
# Create a separate Notion integration limited to the demo workspace only.
NOTION_API_TOKEN=REPLACE_WITH_DEMO_NOTION_TOKEN
NOTION_ROOT_PAGE_ID=REPLACE_WITH_DEMO_PAGE_ID
NOTION_COMMAND_CENTER_ID=
NOTION_DAILY_PLANNER_DB_ID=
NOTION_WEEKLY_PLANNER_DB_ID=
NOTION_WEEKEND_PLANNER_DB_ID=
NOTION_BOARD_DB_ID=

# ── Email / WhatsApp (optional — use throwaway credentials for demos) ─────────
# For demos, either skip these or use a dedicated demo Gmail account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
DIGEST_FROM_EMAIL=
DIGEST_TO_EMAIL=

# ── Schedule / Capacity ───────────────────────────────────────────────────────
WEEKEND_CAPACITY_HOURS=3
TZ=Europe/Lisbon

# ── NOT present in this file (intentionally) ─────────────────────────────────
# GOOGLE_AI_API_KEY  — stays on your VPS, inside the LiteLLM proxy
# GROQ_API_KEY       — stays on your VPS, inside the LiteLLM proxy
# CALLMEBOT_API_KEY  -- use a dedicated demo account if needed
