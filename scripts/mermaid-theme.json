{
    "theme": "base",
    "themeVariables": {
        "fontFamily": "Arial, Helvetica, sans-serif",
        "fontSize": "16px",
        "background": "#ffffff",
        "primaryColor": "#14365d",
        "primaryTextColor": "#ffffff",
        "primaryBorderColor": "#38b2ac",
        "secondaryColor": "#1a365d",
        "secondaryTextColor": "#ffffff",
        "secondaryBorderColor": "#38b2ac",
        "tertiaryColor": "#0f2744",
        "tertiaryTextColor": "#ffffff",
        "tertiaryBorderColor": "#38b2ac",
        "mainBkg": "#14365d",
        "secondBkg": "#1a365d",
        "lineColor": "#4a5568",
        "textColor": "#2d3748",
        "titleColor": "#14365d",
        "edgeLabelBackground": "#f7f7f7",
        "clusterBkg": "#eef4fb",
        "clusterBorder": "#14365d",
        "labelBackground": "#f7f7f7",
        "nodeBorder": "#38b2ac",
        "noteBkgColor": "#fff9c4",
        "noteTextColor": "#2d3748",
        "noteBorderColor": "#cbd5e0",
        "activationBkgColor": "#38b2ac",
        "activationBorderColor": "#14365d",
        "sequenceNumberColor": "#ffffff",
        "signalColor": "#2d3748",
        "signalTextColor": "#2d3748",
        "actorBkg": "#14365d",
        "actorTextColor": "#ffffff",
        "actorLineColor": "#4a5568",
        "actorBorder": "#38b2ac",
        "labelBoxBkgColor": "#14365d",
        "labelBoxBorderColor": "#38b2ac",
        "labelTextColor": "#ffffff",
        "loopTextColor": "#2d3748"
    },
    "flowchart": {
        "curve": "basis",
        "htmlLabels": true,
        "padding": 16,
        "useMaxWidth": true
    },
    "sequence": {
        "useMaxWidth": true,
        "diagramMarginX": 30,
        "diagramMarginY": 20,
        "actorMargin": 60,
        "width": 160,
        "height": 70
    }
}